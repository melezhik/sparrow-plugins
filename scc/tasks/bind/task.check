# 6. zone.<name>.masters – soft, collect masters per zone
~regexp: zone \. ( <-[ \= \; ]>+ ) \. masters \s* \= \s* ( <-[ \; ]>+ ) \s* \;?
code: <<CODE
!python
import sparrow6lib
state = sparrow6lib.get_state()
state.setdefault('zone-masters', {})
for c in sparrow6lib.captures():
    zone = c[0]
    state['zone-masters'][zone] = c[1]
sparrow6lib.update_state(state)
CODE
