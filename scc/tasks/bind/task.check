# 7. Final hard check #1: all zones must have valid type (master, slave, secondary)
generator: <<CODE
!python
import sparrow6lib
state = sparrow6lib.get_state()
zone_types = state.get('zone-types', {})
if zone_types:
    invalid = [z for z, t in zone_types.items() if t not in ('master', 'slave', 'secondary')]
    if invalid:
        print(f"assert: 0 zones with invalid type: {', '.join(invalid)}")
    else:
        print("assert: 1 all zones have valid type")
else:
    print("assert: 1 no zones defined")
CODE

# 8. Final hard check #2: slave/secondary zones must have non-empty masters
generator: <<CODE
!python
import sparrow6lib
state = sparrow6lib.get_state()
zone_types = state.get('zone-types', {})
zone_masters = state.get('zone-masters', {})
all_ok = True
for zone, ztype in zone_types.items():
    if ztype in ('slave', 'secondary'):
        masters = zone_masters.get(zone, '').strip().strip('{}').strip()
        if masters:
            print(f"assert: 1 zone {zone} ({ztype}) has masters: {masters}")
        else:
            print(f"assert: 0 zone {zone} ({ztype}) missing non-empty masters")
            all_ok = False
CODE
