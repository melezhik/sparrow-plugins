RAKU

# Check 9: Verify Defaults timestamp_timeout is not too long
!regexp: ^^ \h* Defaults \h+ timestamp_timeout \h* \= \h* \d+
generator: << RAKU 
!raku
if matched() {
    my $line = $/;
    if $line ~~ / timestamp_timeout \h* \= \h* (\d+) / {
        my $timeout = $0.Int;
        if $timeout <= 15 {
            say "assert: 1 Defaults timestamp_timeout is set to secure value ($timeout minutes)";
        } else {
            say "assert: 0 Defaults timestamp_timeout is too high ($timeout minutes)";
        }
    }
} else {
    say "assert: 0 Defaults timestamp_timeout is not set";
}
RAKU

# Check 10: Check for ALL=(ALL) ALL without restrictions
~regexp: ^^ \h* <-[\#]> .* ALL \h* \= \h* [\(] \h* ALL \h* [\)] \h* [NOPASSWD \h* \:]? \h* ALL
generator: << RAKU 
!raku
if matched() {
    say "assert: 0 unrestricted sudo access found - ALL=(ALL) ALL";
} else {
    say "assert: 1 no unrestricted sudo access found";
}
RAKU

# Check 11: Verify no commented-out dangerous directives are present
~regexp: ^^ \h* \# \h* .* [NOPASSWD | '!authenticate' | '!requiretty' | '!env_reset']
generator: << RAKU 
!raku
if matched() {
    say "assert: 0 commented-out dangerous directives found";
} else {
    say "assert: 1 no commented-out dangerous directives found";
}
RAKU

