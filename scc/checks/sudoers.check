# Check 7: Verify Defaults rootpw is not set (use targetpw instead for accountability)
~regexp: ^^ \h* Defaults \h+ rootpw
generator: << RAKU 
!raku
if matched() {
    say "assert: 0 Defaults rootpw is set - insecure root password prompt";
} else {
    say "assert: 1 Defaults rootpw is not set - using user's own password";
}
RAKU

