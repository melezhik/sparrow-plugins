# Check 1: Verify passwordless sudo is disabled
~regexp: ^^ \h* <-[\#]> .* [NOPASSWD | '!authenticate']
generator: << RAKU 
!raku
if matched() {
    say "assert: 0 passwordless sudo is enabled - NOPASSWD or !authenticate found";
} else {
    say "assert: 1 passwordless sudo is disabled";
}
RAKU

# Check 2: Verify Defaults requiretty is set
!regexp: ^^ \h* Defaults \h+ [!]? requiretty
generator: << RAKU 
!raku
if matched() {
    say "assert: 1 Defaults requiretty is set";
} else {
    say "assert: 0 Defaults requiretty is not set - unsecure tty handling";
}
RAKU

# Check 3: Verify Defaults env_reset is set
!regexp: ^^ \h* Defaults \h+ [!]? env_reset
generator: << RAKU 
!raku
if matched() {
    say "assert: 1 Defaults env_reset is set";
} else {
    say "assert: 0 Defaults env_reset is not set - environment variables not reset";
}
RAKU

# Check 4: Verify Defaults secure_path is set with safe paths
regexp: ^^ \h* Defaults \h+ secure_path \h* \= \h* (\S+)
generator: << RAKU 
!raku
if matched() {
    my $path = capture(0);
    if $path eq '' {
        say "assert: 0 Defaults secure_path is empty";
    } elsif $path.contains('..') {
        say "assert: 0 Defaults secure_path contains relative paths - $path";
    } elsif $path.starts-with('/') && $path.contains('/usr') {
        say "assert: 1 Defaults secure_path is set with safe paths - $path";
    } else {
        say "assert: 0 Defaults secure_path may be insecure - $path";
    }
} else {
    say "assert: 0 Defaults secure_path is not set";
}
RAKU

